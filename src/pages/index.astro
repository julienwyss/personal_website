---
import DesktopShell from "../components/desktop/DesktopShell.astro";
import "../styles/global.css";
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, interactive-widget=resizes-content" />
    <meta http-equiv="Content-Security-Policy" content="
      default-src 'self';
      script-src 'self' *.linkedin.com *.licdn.com 'unsafe-inline';
      connect-src 'self' api.web3forms.com *.linkedin.com *.licdn.com;
      img-src 'self' data: https:;
      style-src 'self' 'unsafe-inline' *.linkedin.com *.licdn.com fonts.googleapis.com;
      font-src 'self' data: *.linkedin.com *.licdn.com fonts.gstatic.com;
      frame-src *.linkedin.com;
      object-src 'none';
    " />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Julien Wyss | Cybersecurity & Software Engineering Portfolio</title>
    <meta name="description" content="Personal portfolio of Julien Wyss. Explore my interactive desktop environment, CTF writeups, software engineering projects, and cybersecurity skills." />
    
    <meta property="og:title" content="Julien Wyss | Portfolio" />
    <meta property="og:description" content="Personal portfolio of Julien Wyss. Explore my CTF writeups and projects." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://julien-wyss.ch/" />
    <meta property="og:image" content="https://julien-wyss.ch/ProfilePicture.jpg" />

    <meta name="robots" content="index, follow" />
    <script src="https://platform.linkedin.com/badges/js/profile.js" async defer></script>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Julien Wyss",
      "url": "https://julien-wyss.ch",
      "image": "https://julien-wyss.ch/ProfilePicture.jpg",
      "jobTitle": "Cybersecurity Enthusiast & Software Engineer",
      "sameAs": [
        "https://github.com/julienwyss",
        "https://www.linkedin.com/in/julien-wyss-39004028b",
      ]
    }
    </script>
  </head>
  <body>
    <h1 class="sr-only">Julien Wyss - Cybersecurity and Software Engineering Portfolio</h1>
    <DesktopShell />
  </body>
</html>

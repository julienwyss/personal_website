---
import ToolTips from "../utils/ToolTips.astro";

const baseUrl = import.meta.env.BASE_URL;
const profilePictureSrc = `${baseUrl}ProfilePicture.jpg`;
const githubLogoSrc = `${baseUrl}github-logo-inverted.svg`;
const linkedinLogoSrc = `${baseUrl}linkedin-logo-white.png`;
---

<div id="taskbar" class="bg-zinc-800 border-zinc-700 flex items-center gap-4">
  <button
    data-tooltip-target="tooltip-profile-picture"
    data-tooltip-placement="right"
    class="w-10 h-10 rounded-md bg-zinc-700 hover:bg-zinc-600 text-zinc-200 flex items-center justify-center"
    onclick={`window.openApp('image-viewer', { src: '${profilePictureSrc}', title: 'Profile Picture' })`}
  >
    <img src={profilePictureSrc} alt="Profile Picture" class="w-full h-full object-cover rounded-md" />
  </button>
  <button
    data-tooltip-target="tooltip-terminal"
    data-tooltip-placement="right"
    type="button"
    class="w-10 h-10 rounded-md bg-zinc-700 hover:bg-zinc-600 text-zinc-200 flex items-center justify-center cursor-pointer font-black text-xl"
    onclick="window.openApp('terminal')"
  >
    <span class="text-red-500">></span><span class="text-white">_</span>
  </button>
  <button
    data-tooltip-target="tooltip-writeups"
    data-tooltip-placement="right"
    type="button"
    class="w-10 h-10 rounded-md bg-zinc-700 hover:bg-zinc-600 text-zinc-200 flex items-center justify-center cursor-pointer transition-colors"
    onclick="window.openApp('explorer')"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#facc15" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="filter: drop-shadow(0 0 5px #facc15aa);">
      <path d="M4 20h16a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.93a2 2 0 0 1-1.66-.9l-.82-1.2A2 2 0 0 0 7.93 2H4a2 2 0 0 0-2 2v13c0 1.1.9 2 2 2Z"></path>
    </svg>
  </button>
  <button
    data-tooltip-target="tooltip-contact"
    data-tooltip-placement="right"
    type="button"
    class="w-10 h-10 rounded-md bg-zinc-700 hover:bg-zinc-600 text-zinc-200 flex items-center justify-center cursor-pointer"
    onclick="window.openApp('contact')"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#38bdf8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="filter: drop-shadow(0 0 3px #38bdf888);">
      <rect x="2" y="4" width="20" height="16" rx="2" />
      <polyline points="2,4 12,13 22,4" />
    </svg>
  </button>
  <button
    data-tooltip-target="tooltip-ctftime"
    data-tooltip-placement="right"
    type="button"
    class="w-10 h-10 rounded-md bg-zinc-700 hover:bg-zinc-600 text-zinc-200 flex items-center justify-center cursor-pointer"
    onclick="window.openApp('ctftime')"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#ff003c" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="filter: drop-shadow(0 0 4px #ff003caa);">
      <path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"></path>
      <line x1="4" y1="22" x2="4" y2="15"></line>
    </svg>
  </button>
  <button
    data-tooltip-target="tooltip-github"
    data-tooltip-placement="right"
    type="button"
    class="w-10 h-10 rounded-md bg-zinc-700 hover:bg-zinc-600 text-zinc-200 flex items-center justify-center cursor-pointer"
    onclick="window.openApp('github')"
  >
    <img src={githubLogoSrc} alt="GitHub Logo" class="w-full h-full object-cover rounded-md" />
  </button>
  <button
    data-tooltip-target="tooltip-linkedin"
    data-tooltip-placement="right"
    type="button"
    class="w-10 h-10 rounded-md bg-zinc-700 hover:bg-zinc-600 text-zinc-200 flex items-center justify-center cursor-pointer"
    onclick="window.openApp('linkedin')"
  >
    <img src={linkedinLogoSrc} alt="LinkedIn Logo" class="w-full h-full object-cover rounded-md" />
  </button>
  <button
    data-tooltip-target="tooltip-help"
    data-tooltip-placement="right"
    type="button"
    class="w-10 h-10 rounded-md bg-zinc-700 hover:bg-zinc-600 flex items-center justify-center cursor-pointer font-black text-xl"
    onclick="window.openApp('help')"
    style="color: #ff2233; text-shadow: 0 0 8px #ff2233, 0 0 16px #ff2233;"
  >
    ?
  </button>
  <ToolTips />
</div>

<script>
  function updateTaskbarLayout() {
    const taskbar = document.getElementById('taskbar');
    if (!taskbar) return;

    if (window.innerWidth >= 768) {
      taskbar.style.gap = '';
      return;
    }

    const buttons = Array.from(taskbar.querySelectorAll('button'));
    const buttonCount = buttons.length;
    if (buttonCount === 0) return;

    const buttonSize = 44;
    const paddingH = 4;
    const fixedGap = 4;
    const available = taskbar.clientWidth - paddingH * 2;
    const totalButtonWidth = buttonCount * buttonSize;

    if (totalButtonWidth <= available) {
      taskbar.style.gap = '0px';
    } else {
      taskbar.style.gap = `${fixedGap}px`;
    }
  }

  window.addEventListener('load', updateTaskbarLayout);
  window.addEventListener('resize', updateTaskbarLayout);
</script>

---
import ctftimeData from '../../data/ctftime.json';

type Team = {
  id?: number;
  name: string;
  url: string;
  country?: string | null;
  website?: string | null;
  rating?: Record<string, { rating_place: number; organizer_points: number; rating_points: number; country_place: number }>;
  aliases?: string[];
};

type CTFEvent = {
  id?: number;
  name: string;
  url: string;
  ctf_url?: string | null;
  format?: string | null;
  location?: string | null;
  start?: string | null;
  finish?: string | null;
  weight?: number | null;
  team_id?: number;
  team_name?: string;
  place?: number | null;
  points?: number | null;
};

type CTFtimeData = {
  handle: string;
  real_name?: string;
  profile_url: string;
  member_since?: string;
  generatedAt?: string;
  teams?: Team[];
  events?: CTFEvent[];
};

const data = ctftimeData as unknown as CTFtimeData;

function formatDate(iso: string | null | undefined): string {
  if (!iso) return '';
  return new Date(iso).toLocaleDateString('de-CH', { day: '2-digit', month: '2-digit', year: 'numeric' });
}

const currentYear = new Date().getFullYear().toString();
---

<div class="h-full overflow-y-auto bg-zinc-950 text-zinc-100 font-mono">

  <div class="relative w-full px-5 pt-5 pb-5" style="background: linear-gradient(135deg, #0f1923 0%, #1a0a2e 100%); border-bottom: 1px solid rgba(255,0,60,0.2);">
    <div class="flex items-center gap-4">
      <div class="w-14 h-14 rounded-lg flex items-center justify-center shrink-0" style="background: rgba(255,0,60,0.1); border: 1px solid rgba(255,0,60,0.3);">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#ff003c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7">
          <path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"></path>
          <line x1="4" y1="22" x2="4" y2="15"></line>
        </svg>
      </div>
      <div class="flex-1 min-w-0">
        <div class="text-xs mb-0.5" style="color: #ff003c;">CTFtime.org</div>
        <h2 class="text-xl font-bold tracking-tight">{data.handle}</h2>
        {data.real_name && <div class="text-sm mt-0.5" style="color:#8b949e;">{data.real_name}</div>}
        {data.member_since && (
          <div class="text-xs mt-1" style="color:#555e68;">
            <span style="color:#ff003c;">▸</span> Flags capturing since {data.member_since}
          </div>
        )}
      </div>
      <a
        href={data.profile_url}
        target="_blank"
        rel="noopener noreferrer"
        class="shrink-0 text-xs font-bold px-3 py-1.5 rounded transition-opacity hover:opacity-80"
        style="background: rgba(255,0,60,0.15); color:#ff003c; border: 1px solid rgba(255,0,60,0.4); text-decoration:none;"
      >
        CTFtime →
      </a>
    </div>
  </div>

  {data.teams && data.teams.length > 0 && (
    <div class="px-5 py-4" style="border-bottom: 1px solid rgba(255,255,255,0.06);">
      <h3 class="text-xs font-bold mb-3" style="color:#ff003c; letter-spacing: 0.1em;">TEAMS</h3>
      <div class="flex flex-col gap-2">
        {data.teams.map((team) => {
          const yearRating = team.rating?.[currentYear] ?? team.rating?.[String(Number(currentYear)-1)] ?? null;
          return (
            <a
              href={team.url}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-3 px-3 py-2.5 rounded transition-colors hover:bg-white/5"
              style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.07); text-decoration:none;"
            >
              <div class="w-8 h-8 rounded flex items-center justify-center text-xs font-bold shrink-0" style="background: rgba(255,0,60,0.12); color:#ff003c;">
                {team.name.charAt(0)}
              </div>
              <div class="flex-1 min-w-0">
                <div class="text-sm text-zinc-200 truncate">{team.name}</div>
                {team.country && <div class="text-xs mt-0.5" style="color:#555e68;">{team.country}</div>}
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 shrink-0 ml-1" style="color:#555e68;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                <polyline points="15 3 21 3 21 9"></polyline>
                <line x1="10" y1="14" x2="21" y2="3"></line>
              </svg>
            </a>
          );
        })}
      </div>
    </div>
  )}

  {data.events && data.events.length > 0 && (
    <div class="px-5 py-4">
      <h3 class="text-xs font-bold mb-3" style="color:#ff003c; letter-spacing: 0.1em;">
        CTFs PARTICIPATED ({data.events.length})
      </h3>
      <div class="flex flex-col gap-2">
        {data.events.map((event) => (
          <a
            href={event.url}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-start gap-3 px-3 py-2.5 rounded transition-colors hover:bg-white/5"
            style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.07); text-decoration:none;"
          >
            <span class="text-base shrink-0 mt-0.5" style="color:#ff003c;">⚑</span>
            <div class="flex-1 min-w-0">
              <div class="text-sm text-zinc-200 leading-snug">{event.name}</div>
              <div class="flex flex-wrap gap-x-3 gap-y-0.5 mt-1">
                {event.team_name && (
                  <span class="text-xs" style="color:#70b5f9;">{event.team_name}</span>
                )}
                {event.format && (
                  <span class="text-xs" style="color:#555e68;">{event.format}</span>
                )}
                {event.start && (
                  <span class="text-xs" style="color:#555e68;">{formatDate(event.start)}</span>
                )}
                {event.weight != null && event.weight > 0 && (
                  <span class="text-xs" style="color:#555e68;">weight {event.weight.toFixed(2)}</span>
                )}
              </div>
            </div>
            <div class="shrink-0 text-right">
              {event.place != null && (
                <div class="text-sm font-bold" style="color:#ff003c;">#{event.place}</div>
              )}
              {event.points != null && (
                <div class="text-xs" style="color:#555e68;">{typeof event.points === 'number' ? event.points.toFixed(2) : event.points} pts</div>
              )}
            </div>
          </a>
        ))}
      </div>
      {data.generatedAt && (
        <div class="mt-3 text-right text-xs" style="color:#333c47;">
          Updated: {formatDate(data.generatedAt)}
        </div>
      )}
    </div>
  )}

  {(!data.events || data.events.length === 0) && (
    <div class="px-5 py-8 text-center">
      <div class="text-2xl mb-2">⚑</div>
      <div class="text-sm" style="color:#555e68;">Noch keine Events geladen.</div>
    </div>
  )}

  <div class="h-6"></div>
</div>

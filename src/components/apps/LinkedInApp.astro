---
import linkedinData from '../../data/linkedin.json';

type Experience = {
  company: string;
  title: string;
  duration: string;
  location?: string;
  description?: string;
};

type Education = {
  school: string;
  degree: string;
  field?: string;
  duration?: string;
};

type Certification = {
  name: string;
  issuer?: string;
  date?: string;
};

type LinkedInData = {
  name: string;
  headline?: string;
  location?: string;
  about?: string;
  profile_url: string;
  avatar_url?: string;
  experience?: Experience[];
  education?: Education[];
  certifications?: Certification[];
  skills?: string[];
};

const data = linkedinData as LinkedInData;
---

<div class="h-full overflow-y-auto text-white" style="background:#1b1f23; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;">

  <div class="relative">
    <div class="w-full h-24" style="background: linear-gradient(135deg, #0a66c2 0%, #004182 100%);"></div>

    <div class="absolute left-5 bottom-0 translate-y-1/2">
      {data.avatar_url ? (
        <img
          src={data.avatar_url}
          alt={data.name}
          class="w-20 h-20 rounded-full object-cover"
          style="border: 3px solid #1b1f23;"
        />
      ) : (
        <div class="w-20 h-20 rounded-full flex items-center justify-center text-2xl font-bold" style="background:#0a66c2; border: 3px solid #1b1f23;">
          {data.name.charAt(0)}
        </div>
      )}
    </div>
  </div>

  <div class="px-5 pb-5" style="padding-top: 3.5rem;">
    <div class="flex items-start justify-between gap-3">
      <div>
        <h2 class="text-xl font-bold leading-tight">{data.name}</h2>
        {data.headline && (
          <p class="text-sm mt-1" style="color:#b0b7bc;">{data.headline}</p>
        )}
        {data.location && (
          <p class="text-xs mt-1.5 flex items-center gap-1" style="color:#70b5f9;">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 shrink-0" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
            </svg>
            {data.location}
          </p>
        )}
      </div>
      <a
        href={data.profile_url}
        target="_blank"
        rel="noopener noreferrer"
        class="shrink-0 text-sm font-semibold px-4 py-1.5 rounded-full transition-colors hover:opacity-90"
        style="background:#0a66c2; color:#fff; text-decoration:none;"
      >
        LinkedIn
      </a>
    </div>
  </div>

  <div style="height:1px; background:rgba(255,255,255,0.08); margin: 0 0 4px;"></div>

  {data.about && data.about.trim() !== '' && (
    <div class="px-5 py-4">
      <h3 class="text-base font-semibold mb-2">Über mich</h3>
      <p class="text-sm leading-relaxed" style="color:#b0b7bc;">{data.about}</p>
    </div>
  )}

  {data.experience && data.experience.length > 0 && (
    <div class="px-5 py-4" style="border-top: 1px solid rgba(255,255,255,0.08);">
      <h3 class="text-base font-semibold mb-4">Berufserfahrung</h3>
      <div class="space-y-5">
        {data.experience.map((exp) => (
          <div class="flex gap-3">
            <!-- Firmen-Icon Platzhalter -->
            <div class="w-10 h-10 rounded shrink-0 flex items-center justify-center text-xs font-bold mt-0.5" style="background:#2d3540; color:#70b5f9;">
              {exp.company.charAt(0)}
            </div>
            <div>
              <div class="text-sm font-semibold leading-snug">{exp.title}</div>
              <div class="text-sm" style="color:#b0b7bc;">{exp.company}</div>
              <div class="text-xs mt-0.5" style="color:#8b949e;">{exp.duration}</div>
              {exp.location && (
                <div class="text-xs" style="color:#8b949e;">{exp.location}</div>
              )}
              {exp.description && exp.description.trim() !== '' && (
                <p class="text-sm mt-2 leading-relaxed" style="color:#b0b7bc;">{exp.description}</p>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  )}

  {data.education && data.education.length > 0 && (
    <div class="px-5 py-4" style="border-top: 1px solid rgba(255,255,255,0.08);">
      <h3 class="text-base font-semibold mb-4">Ausbildung</h3>
      <div class="space-y-5">
        {data.education.map((edu) => (
          <div class="flex gap-3">
            <!-- Schul-Icon Platzhalter -->
            <div class="w-10 h-10 rounded shrink-0 flex items-center justify-center text-xs font-bold mt-0.5" style="background:#2d3540; color:#70b5f9;">
              {edu.school.charAt(0)}
            </div>
            <div>
              <div class="text-sm font-semibold leading-snug">{edu.school}</div>
              <div class="text-sm" style="color:#b0b7bc;">
                {edu.degree}{edu.field ? ` · ${edu.field}` : ''}
              </div>
              {edu.duration && (
                <div class="text-xs mt-0.5" style="color:#8b949e;">{edu.duration}</div>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  )}

  {data.certifications && data.certifications.length > 0 && (
    <div class="px-5 py-4" style="border-top: 1px solid rgba(255,255,255,0.08);">
      <h3 class="text-base font-semibold mb-4">Lizenzen & Zertifikate</h3>
      <div class="space-y-4">
        {data.certifications.map((cert) => (
          <div class="flex gap-3">
            <div class="w-10 h-10 rounded shrink-0 flex items-center justify-center text-xs font-bold mt-0.5" style="background:#2d3540; color:#70b5f9;">
              ✓
            </div>
            <div>
              <div class="text-sm font-semibold">{cert.name}</div>
              {cert.issuer && <div class="text-sm" style="color:#b0b7bc;">{cert.issuer}</div>}
              {cert.date && <div class="text-xs mt-0.5" style="color:#8b949e;">{cert.date}</div>}
            </div>
          </div>
        ))}
      </div>
    </div>
  )}

  {data.skills && data.skills.length > 0 && (
    <div class="px-5 py-4" style="border-top: 1px solid rgba(255,255,255,0.08);">
      <h3 class="text-base font-semibold mb-3">Kenntnisse</h3>
      <div class="flex flex-wrap gap-2">
        {data.skills.map((skill) => (
          <span
            class="text-xs px-3 py-1 rounded-full font-medium"
            style="background:#2d3540; color:#70b5f9; border: 1px solid #3a4552;"
          >
            {skill}
          </span>
        ))}
      </div>
    </div>
  )}

  <div class="h-6"></div>
</div>
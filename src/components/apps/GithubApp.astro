---
import githubData from '../../data/github.json';

type GithubAccount = {
  login: string;
  html_url: string;
  created_at: string;
  public_repos: number;
  followers: number;
};

type GithubProfile = {
  login: string;
  avatar_url: string;
  html_url: string;
  created_at: string;
  public_repos: number;
  followers: number;
  message?: string;
};

type GithubRepo = {
  name: string;
  html_url: string;
  description?: string | null;
  language?: string | null;
  stargazers_count: number;
  updated_at?: string;
  account?: string;
  accounts?: string[];
};

type GithubDataShape = {
  profile?: GithubProfile | null;
  accounts?: GithubAccount[];
  repos?: GithubRepo[];
  languageBytes?: Record<string, number>;
  languageBytesTotal?: number;
};

const data = githubData as unknown as GithubDataShape;

let profile: GithubProfile | null = data.profile ?? null;
let accounts: GithubAccount[] = Array.isArray(data.accounts) ? data.accounts : [];
let repos: GithubRepo[] | null = Array.isArray(data.repos) ? data.repos : null;
let apiError: string | null = null;
let languageStats: Record<string, number> = {};
let sortedLanguages: [string, number][] = [];
let languageBytesTotal: number | null = typeof data.languageBytesTotal === 'number' ? data.languageBytesTotal : null;
let usingLanguageBytes = false;
let totalRepos = 0;

try {
  if (!profile || !repos) {
    throw new Error('GitHub-Daten nicht verfügbar.');
  }

  if (data.languageBytes && Object.keys(data.languageBytes).length > 0 && (languageBytesTotal ?? 0) > 0) {
    usingLanguageBytes = true;
    languageStats = data.languageBytes;
    sortedLanguages = Object.entries(languageStats).sort((a, b) => b[1] - a[1]);
  } else {
    for (const repo of repos) {
      if (!repo.language) continue;
      languageStats[repo.language] = (languageStats[repo.language] ?? 0) + 1;
    }
    sortedLanguages = Object.entries(languageStats).sort((a, b) => b[1] - a[1]);
  }

  totalRepos = repos.length;
} catch (error) {
  apiError = (error as Error).message;
  console.error('GitHub Data Error:', error);
}

const accountColors: Record<string, string> = {
  [accounts[0]?.login ?? '']: 'text-cyan-400 border-cyan-800 bg-cyan-950',
  [accounts[1]?.login ?? '']: 'text-violet-400 border-violet-800 bg-violet-950',
};
---

<div class="h-full overflow-y-auto bg-zinc-900 text-zinc-200 p-6">

{(apiError || !profile || !repos) ? (
  <div class="h-full flex items-center justify-center">
    <div class="text-center">
      <div class="text-6xl mb-4">
        <img src={`${import.meta.env.BASE_URL}warning-symbol.svg`} alt="Warning Symbol" class="w-16 h-16 mx-auto mb-4">
      </div>
      <h2 class="text-xl font-bold mb-2">GitHub API Fehler</h2>
      <p class="text-zinc-400 mb-4">
        {(apiError ?? '').includes('rate limit') 
          ? 'Rate limit erreicht. Versuche es später nochmal.'
          : `Fehler: ${apiError ?? 'GitHub-Daten nicht verfügbar.'}`
        }
      </p>
      <p class="text-zinc-500 text-sm">
        Die GitHub API ist momentan nicht verfügbar.
      </p>
    </div>
  </div>
) : (
  <>
  <div class="flex items-center gap-6">
    <img
      src={profile.avatar_url}
      class="w-20 h-20 rounded-full border border-zinc-700 shrink-0"
    />

    <div class="flex flex-col gap-2">
      {accounts.length > 0 ? accounts.map((acc) => (
        <div class="flex items-center gap-3">
          <span
            class={`text-xs px-2 py-0.5 rounded border font-mono ${accountColors[acc.login] ?? 'text-zinc-400 border-zinc-700 bg-zinc-800'}`}
          >
            {acc.login}
          </span>
          <a
            href={acc.html_url}
            target="_blank"
            class="text-zinc-400 text-sm hover:text-zinc-200 hover:underline transition-colors"
          >
            Open on GitHub →
          </a>
        </div>
      )) : (
        <div class="flex items-center gap-3">
          <a
            href={profile.html_url}
            target="_blank"
            class="text-cyan-400 text-sm hover:underline"
          >
            {profile.login} – Open on GitHub →
          </a>
        </div>
      )}
    </div>
  </div>

  <div class="mt-6 flex gap-8 text-sm">
    <div>
      <span class="text-zinc-400">Repos</span>
      <div class="text-lg font-semibold">{totalRepos}</div>
    </div>
    {accounts.map((acc) => (
      <div>
        <span class={`text-xs ${accountColors[acc.login]?.split(' ')[0] ?? 'text-zinc-400'}`}>{acc.login}</span>
        <div class="text-lg font-semibold">{acc.public_repos}</div>
      </div>
    ))}
  </div>

  <div class="mt-10">
    <h3 class="text-sm uppercase text-zinc-500 tracking-wider mb-4">
      Repositories
    </h3>

    {repos.map((repo: GithubRepo) => {
      const repoAccounts: string[] = (repo as any).accounts ?? (repo.account ? [repo.account] : []);
      return (
        <div class="mb-5 pb-4 border-b border-zinc-800">
          <div class="flex items-center justify-between gap-2">
            <a
              href={repo.html_url}
              target="_blank"
              class="text-cyan-400 font-semibold text-base hover:underline"
            >
              {repo.name}
            </a>
            <div class="flex gap-1 shrink-0">
              {repoAccounts.map((acc) => (
                <span
                  class={`text-xs px-1.5 py-0.5 rounded border font-mono ${accountColors[acc] ?? 'text-zinc-400 border-zinc-700 bg-zinc-800'}`}
                >
                  {acc}
                </span>
              ))}
            </div>
          </div>

          {repo.description && (
            <p class="text-sm text-zinc-400 mt-1">
              {repo.description}
            </p>
          )}

          <div class="flex gap-6 text-xs text-zinc-500 mt-2">
            {repo.language && <span>{repo.language}</span>}
          </div>
        </div>
      );
    })}
  </div>

  {sortedLanguages.length > 0 && (
    <div class="mt-10">
      <h3 class="text-sm uppercase text-zinc-500 tracking-wider mb-4">
        Languages
      </h3>

      <div class="space-y-3">
        {sortedLanguages.map(([lang, count]: [string, number]) => {
          const denom = usingLanguageBytes ? (languageBytesTotal ?? 0) : repos!.length;
          const percent = denom > 0 ? (count / denom) * 100 : 0;

          return (
            <div>
              <div class="flex justify-between text-sm">
                <span>{lang}</span>
                <span class="text-zinc-400">{usingLanguageBytes ? `${percent.toFixed(1)}%` : count}</span>
              </div>

              <div class="bg-zinc-800 h-2 rounded mt-1">
                <div
                  class="bg-cyan-500 h-2 rounded"
                  style={`width: ${percent}%`}
                />
              </div>
            </div>
          );
        })}
      </div>
    </div>
  )}
  </>
)}

</div>
